# Environment variables for ghostRbot

# Server
PORT=8002

# Database
DATABASE_URL=postgresql://ghostrbot:ghostrbot@localhost:5432/ghostrbot

# Admin
ADMIN_PASSWORD=your_admin_password_here
SESSION_SECRET=auto_generated_if_not_set

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Exchange
EXCHANGE_ENCRYPTION_KEY=

# API Keys
BIRDEYE_API_KEY=
HELIUS_API_KEY=
OPENAI_API_KEY=

# Blockchain RPCs
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
BSC_RPC_URL=https://bsc-dataseed.binance.org

# Fees
FEE_WALLET=
BUY_FEE_PERCENT=0.5
SELL_FEE_PERCENT=0.5

# Logging
RUST_LOG=info
